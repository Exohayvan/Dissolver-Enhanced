{
    "schemaVersion": 1,
    "id": "dissolver_enhanced",
    "version": "${version}",
    "name": "Dissolver Enhanced",
    "description": "Convert items into any other stored items based on its value (EMC).",
    "authors": ["ExoHayvan"],
    "contact": {
        "homepage": "https://github.com/ExoHayvan/Dissolver-Enhanced",
        "sources": "https://github.com/ExoHayvan/Dissolver-Enhanced",
        "issues": "https://github.com/ExoHayvan/Dissolver-Enhanced/issues"
    },
    "license": "MIT",
    "icon": "assets/dissolver_enhanced/icon.png",
    "environment": "*",
    "entrypoints": {
        "main": ["net.exohayvan.dissolver_enhanced.DissolverEnhanced"],
        "client": ["net.exohayvan.dissolver_enhanced.DissolverEnhancedClient"]
    },
    "mixins": [
        "dissolver_enhanced.mixins.json",
        {
            "config": "dissolver_enhanced.client.mixins.json",
            "environment": "client"
        }
    ],
    "depends": {
        "fabricloader": ">=0.19.2",
        "minecraft": "26.1.2",
        "java": ">=25",
        "fabric-api": "*"
    },
    "suggests": {
        "another-mod": "*"
    }
}
